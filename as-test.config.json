{
  "$schema": "./node_modules/as-test/as-test.config.schema.json",
  "input": ["./assembly/__tests__/*.spec.ts"],
  "outDir": "./.as-test/build",
  "logs": "./.as-test/logs",
  "coverageDir": "./.as-test/coverage",
  "snapshotDir": "./.as-test/snapshots",
  "config": "none",
  "coverage": false,
  "buildOptions": {
    "args": ["--debug", "--enable", "simd", "--enable", "bulk-memory"],
    "target": "wasi"
  },
  "fuzz": {
    "input": ["./assembly/__fuzz__/*.fuzz.ts"],
    "runs": 1000,
    "seed": 1337,
    "target": "bindings"
  },
  "runOptions": {
    "runtime": {
      "cmd": "wasmtime <file>"
    }
  },
  "modes": {
    "simd": {
      "default": true
    },
    "nosimd": {
      "default": true,
      "buildOptions": {
        "target": "wasi",
        "args": ["--debug", "--enable", "bulk-memory", "--disable", "simd"]
      }
    }
  }
}
